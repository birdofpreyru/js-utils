{
  "extends": "@tsconfig/recommended",
  "include": ["src"],
  "compilerOptions": {
    "declaration": true,
    "emitDeclarationOnly": true,
    "module": "preserve",
    "moduleResolution": "bundler",
    "outDir": "build/types",
    "rootDir": "./src",
    "types": ["node"],
    "verbatimModuleSyntax": true
  }
}
